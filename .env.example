# ===== Panel runtime =====
PANEL_DATA_DIR=/var/lib/vui-plan
PANEL_TIMEZONE=Asia/Shanghai
PANEL_TIMEZONE_LABEL="北京时间 (UTC+8)"
PANEL_DEFAULT_TITLE="V UI"
PANEL_DEFAULT_DOMAIN=panel.example.com
PANEL_DEFAULT_FLOW=xtls-rprx-vision
PANEL_SERVICE_NAME=vui-plan
PANEL_RUNTIME=docker
PANEL_CONTAINER_NAME=vui-plan
PANEL_BIND_HOST=127.0.0.1
PANEL_RUNTIME_MODE=systemd
PANEL_SESSION_COOKIE_SECURE=1
PANEL_MANAGE_FIREWALL=1
PANEL_SYSTEMCTL_COMMAND=systemctl
PANEL_TRUSTED_PROXY_IPS=127.0.0.1,::1
PANEL_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
PANEL_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
PANEL_LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=900
PANEL_BOOTSTRAP_OWNER_USERNAME=admin
# PANEL_BOOTSTRAP_OWNER_PASSWORD=

# ===== Xray runtime =====
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
XRAY_ENV_PATH=/root/xray-reality-main.env
XRAY_BIN=/usr/local/bin/xray
XRAY_API_SERVER=127.0.0.1:10085
XRAY_LOG_DIR=/var/log/xray

# ===== Installer =====
DOMAIN=panel.example.com
TLS_CERT=/etc/letsencrypt/live/panel.example.com/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/panel.example.com/privkey.pem
INSTALL_DIR=/opt/vui-plan
SERVICE_NAME=vui-plan
PANEL_PORT=9200
PANEL_USER=root

# ===== Reality =====
REALITY_PORT=30828
REALITY_SERVER_DOMAIN=panel.example.com
REALITY_SNI=panel.example.com
REALITY_TARGET=127.0.0.1:443
REALITY_UUID=
REALITY_EMAIL=admin@example.com
REALITY_SHORT_ID=
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
INSTALL_XRAY_IF_MISSING=1
